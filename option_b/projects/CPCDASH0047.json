  "analytical_questions": {
    "primary_question": "Can self-supervised wearable sensor representations support activity classification across wrist and thigh datasets?",
    "other_questions": [
      "Can a Capture24 wrist classifier identify sit-stand, sleep, walking, bicycling, vehicle, and mixed activities?",
      "Can Sydney wrist and thigh classifiers identify sitting, standing, walking, cycling, and related activities?",
      "How well do classifiers transfer between Capture24 and Sydney wearable datasets?",
      "Which normalisation strategy improves cross-dataset wearable activity classification?"
    ]
  },
  "qc": [
    {
      "qc_question": "Are wearable datasets harmonised to a common format?",
      "qc_method": "Finland, Sydney, and Capture24 preprocessing scripts"
    },
    {
      "qc_question": "Is classifier performance stable across folds?",
      "qc_method": "5-fold cross-validation"
    },
    {
      "qc_question": "Are class-level errors interpretable?",
      "qc_method": "row-normalised confusion matrices"
    },
    {
      "qc_question": "Does normalisation affect transfer performance?",
      "qc_method": "Sydney, Capture24, and subject-wise normalisation compared"
    },
    {
      "qc_question": "Does the model generalise across datasets and sensor placements?",
      "qc_method": "Capture24-to-Sydney wrist/thigh transfer evaluation"
    }
  ],
